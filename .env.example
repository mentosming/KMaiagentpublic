# ======================================
# Nexus-OS v1.1 環境變數範本
# 複製此檔為 .env 並填入真實數值
# ======================================

# --- AI 模型 ---
# Gemini API 金鑰（用於 gemini-3.1-pro 呼叫與文字嵌入）
GEMINI_API_KEY=your_gemini_api_key_here

# --- 資料庫 ---
# PostgreSQL 連線字串（需安裝 pgvector 擴充）
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nexus_os

# --- Google 服務憑證 ---
# Google Drive / Calendar API 憑證 JSON 檔路徑
# 可為 Service Account JSON 或 OAuth2 憑證
GOOGLE_DRIVE_CREDENTIALS=/path/to/credentials.json

# （可選）指定預設行事曆 ID，留空則使用 primary
GOOGLE_CALENDAR_ID=primary

# --- Telegram Bot ---
# 從 @BotFather 取得的 Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Zeabur 部署時填入（格式：https://你的域名）
# 留空則使用 Polling 模式（本地開發）
WEBHOOK_URL=

# Zeabur 自動注入的端口（無需手動設定）
# PORT=8443

# --- 系統設定 ---
# 記憶體檢索時返回的相似對話數量上限
MEMORY_TOP_K=5
# 嵌入向量維度（Gemini text-embedding-004 = 768）
EMBEDDING_DIM=768

# --- 系統管理員與優化師 (Optimizer Agent) ---
# 管理員 Telegram ID，逗號分隔
ADMIN_IDS=

# GitHub 儲存庫設定（供優化師自動 Commit 與 Rollback 用）
GITHUB_REPO=
GITHUB_TOKEN=

# --- 認證與 OAuth ---
# 後端 API 域名（供 Google OAuth callback redirect 用）
BACKEND_URL=http://localhost:8000

# Google OAuth2 Web Application 憑證（用於 Google Calendar）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 加密金鑰（32 字元隨機字串，用於敏感資料加密）
SECRET_KEY=CHANGE_ME_please_use_32_chars_minimum_random_string

# --- Web3 Agent Wallet ---
# Base Network Public RPC URL
RPC_URL=https://mainnet.base.org

# Solana Network Public RPC URL
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# (可選) Agent 的 Base (EVM) 與 Solana 私鑰。若留空則啟動時會自動生成並儲存在 .env 檔案中
# AGENT_PRIVATE_KEY=your_base_private_key_here
# AGENT_SOLANA_PRIVATE_KEY=your_solana_base58_private_key_here
